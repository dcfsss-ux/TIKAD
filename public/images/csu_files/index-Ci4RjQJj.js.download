 classics."},{name:"PDFDRIVE",description:"Search engine allowing preview and download of millions of PDF files."}],n=Ce(()=>a.filter(s=>s.name.toLowerCase().includes(e.value.toLowerCase())||s.description.toLowerCase().includes(e.value.toLowerCase())));return We(()=>{document.querySelectorAll(".group").forEach(s=>{const o=s.querySelector(".card-accent"),l=s.querySelector(".card-bar");s.addEventListener("mouseenter",()=>{o&&(o.style.transform="scaleX(1)"),l&&(l.style.transform="scaleX(1)")}),s.addEventListener("mouseleave",()=>{o&&(o.style.transform="scaleX(0)"),l&&(l.style.transform="scaleX(0)")})})}),(s,o)=>(_(),C("div",PZ,[r("div",qZ,[r("div",TZ,[r("div",EZ,[r("div",RZ,[r("button",{onClick:o[0]||(o[0]=l=>s.$router.back()),class:"inline-flex items-center gap-1 text-sm font-semibold text-[#1b5e20] hover:underline"},[...o[4]||(o[4]=[r("svg",{class:"w-4 h-4",fill:"none",viewBox:"0 0 24 24",stroke:"currentColor"},[r("path",{"stroke-linecap":"round","stroke-linejoin":"round","stroke-width":"2.5",d:"M15 19l-7-7 7-7"})],-1),be(" Back ",-1)])]),o[5]||(o[5]=r("span",{style:{"font-size":"0.75rem","font-weight":"700",color:"#1b5e20","border-left":"3px solid #1b5e20","padding-left":"8px"}},"Records",-1)),o[6]||(o[6]=r("span",{style:{"font-size":"0.75rem","font-weight":"700",color:"#1b5e20","border-left":"3px solid #f9a825","padding-left":"8px"}},"Caraga State University Library",-1))])]),o[8]||(o[8]=r("div",{class:"anim-slide-up"},[r("h1",{style:{"font-size":"2.2rem","font-weight":"900",color:"#0d2b0f","line-height":"1.2"},class:"mb-2"}," E-Resources "),r("p",{style:{"font-size":"0.95rem",color:"#555","max-width":"520px","line-height":"1.6"}}," Academic databases, journals, digital libraries, and open-access platforms supporting research and lifelong learning. ")],-1)),r("div",BZ,[r("div",HZ,[(_(),C("svg",OZ,[...o[7]||(o[7]=[r("circle",{cx:"11",cy:"11",r:"8"},null,-1),r("path",{d:"m21 21-4.35-4.35"},null,-1)])]))]),ke(r("input",{"onUpdate:modelValue":o[1]||(o[1]=l=>e.value=l),